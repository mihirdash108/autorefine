# autorefine — LLM backend configuration
# Copy this to .env and fill in your credentials.
# Only ONE backend is required.

# --- Option 1: OpenAI (recommended) ---
# OPENAI_API_KEY=sk-...

# --- Option 2: Azure OpenAI ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_MODEL=gpt-4o

# --- Option 3: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Option 4: Ollama (local, free) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Override backend detection ---
# AUTOREFINE_BACKEND=openai    # force: openai|azure|anthropic|ollama
# AUTOREFINE_MODEL=gpt-4o     # override model name
